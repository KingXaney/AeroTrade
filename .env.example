# ---------------------------------------------------------------------------
# AeroTrade Terminal — environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# On Vercel, set these under Project → Settings → Environment Variables.
# ---------------------------------------------------------------------------

# --- Database (MongoDB Atlas connection string) ---
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>"

# --- Better Auth ---
# Generate a strong secret, e.g. `openssl rand -base64 32`
BETTER_AUTH_SECRET="your-32+-char-random-secret"
# The canonical URL of the deployment. Use http://localhost:3000 locally,
# and your production URL (e.g. https://your-app.vercel.app) in production.
BETTER_AUTH_URL="http://localhost:3000"

# --- Google Gemini (AI chat assistant + Inngest email summaries) ---
GEMINI_API_KEY="your-gemini-api-key"

# --- Finnhub (stock quotes, search, company news) ---
# Exposed to the browser (NEXT_PUBLIC_*); use a key scoped accordingly.
NEXT_PUBLIC_FINNHUB_API_KEY="your-finnhub-api-key"

# --- Nodemailer (Gmail) for transactional/news emails ---
NODEMAILER_EMAIL="your-gmail-address@gmail.com"
# Use a Gmail App Password (not your account password).
NODEMAILER_PASSWORD="your-gmail-app-password"

# --- Inngest (background jobs: welcome + daily news emails) ---
# Local development only: forces the Inngest dev server. Remove/omit in production.
INNGEST_DEV="1"
# Required in production (from the Inngest dashboard). Leave unset for local dev.
# INNGEST_EVENT_KEY="your-inngest-event-key"
# INNGEST_SIGNING_KEY="your-inngest-signing-key"
